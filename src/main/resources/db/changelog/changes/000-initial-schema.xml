<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- 1. ТАБЛИЦА КАРТ -->
    <changeSet id="0.1" author="dmitry">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="taro_cards"/>
            </not>
        </preConditions>
        <comment>Создание базовой таблицы taro_cards, если её нет</comment>

        <createTable tableName="taro_cards">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name_en" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name_ru" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="arcana" type="VARCHAR(50)"/>
            <column name="suit" type="VARCHAR(50)"/>
            <column name="number" type="INTEGER"/>
            <column name="upright" type="TEXT"/>
            <column name="reversed" type="TEXT"/>
            <column name="image_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 2. ТАБЛИЦА ПОЛЬЗОВАТЕЛЕЙ -->
    <changeSet id="0.2" author="dmitry">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="users"/>
            </not>
        </preConditions>
        <comment>Создание таблицы пользователей users</comment>
        <createTable tableName="users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- 3. ТАБЛИЦА РАСКЛАДОВ -->
    <changeSet id="0.3" author="dmitry">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="taro_layouts"/>
            </not>
        </preConditions>
        <comment>Создание таблицы taro_layouts и индексов для неё</comment>
        <createTable tableName="taro_layouts">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="layout_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="session_id" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_layout_user" referencedTableName="users" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createIndex indexName="idx_layout_user_date" tableName="taro_layouts">
            <column name="user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <createIndex indexName="idx_layout_session_date" tableName="taro_layouts">
            <column name="session_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
    </changeSet>

    <!-- 4. ТАБЛИЦА ИСТОРИИ КАРТ В РАСКЛАДЕ -->
    <changeSet id="0.4" author="dmitry">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="taro_history"/>
            </not>
        </preConditions>
        <comment>Создание таблицы taro_history</comment>
        <createTable tableName="taro_history">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="is_reversed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="card_order" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="card_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="layout_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="taro_history" baseColumnNames="card_id"
                                 constraintName="fk_history_card"
                                 referencedTableName="taro_cards" referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="taro_history" baseColumnNames="layout_id"
                                 constraintName="fk_history_layout"
                                 referencedTableName="taro_layouts" referencedColumnNames="id"
                                 onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
