<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- 1. Индекс для связки истории и расклада -->
    <changeSet id="4.1-create-index-taro-history-layout-order" author="dmitry">
        <comment>Ускоряет загрузку карт внутри расклада в правильном порядке</comment>
        <createIndex indexName="idx_taro_history_layout_order" tableName="taro_history">
            <column name="layout_id"/>
            <column name="card_order"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_taro_history_layout_order" tableName="taro_history"/>
        </rollback>
    </changeSet>

    <!-- 2. Одиночный индекс по картам -->
    <changeSet id="4.2-create-index-taro-history-card" author="dmitry">
        <createIndex indexName="idx_taro_history_card" tableName="taro_history">
            <column name="card_id"/>
        </createIndex>
        <rollback>
            <dropIndex indexName="idx_taro_history_card" tableName="taro_history"/>
        </rollback>
    </changeSet>

    <!-- 3. Индекс для истории авторизованного пользователя -->
    <changeSet id="4.3-create-index-taro-layouts-user-created" author="dmitry" dbms="postgresql">
        <comment>Индекс для авторизованных пользователей, исключая гостей</comment>
        <sql>
            CREATE INDEX IF NOT EXISTS idx_taro_layouts_user_created_not_null
                ON taro_layouts (user_id, created_at DESC)
                WHERE user_id IS NOT NULL;
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_taro_layouts_user_created_not_null;
        </rollback>
    </changeSet>

    <!-- 4. Индекс для гостевых сессий-->
    <changeSet id="4.4-create-index-taro-layouts-session-created" author="dmitry" dbms="postgresql">
        <comment>Индекс для гостей, автоматически худеет при авторизации сессии</comment>
        <sql>
            CREATE INDEX IF NOT EXISTS idx_taro_layouts_session_guest_created
                ON taro_layouts (session_id, created_at DESC)
                WHERE user_id IS NULL;
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_taro_layouts_session_guest_created;
        </rollback>
    </changeSet>

</databaseChangeLog>
